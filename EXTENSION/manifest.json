{
    "manifest_version": 3,
    "name": "NO lateral bar",
    "version": "1.1", 
    "description": "extension para elmiminar la barra lateral de youtube",
    "author": "JCAS",
    "icons": {
        "16": "icon/bug-2-line.png",
        "48": "icon/bug-2-line.png",
        "128": "icon/bug-2-line.png"
    },
    "action": {
        "default_popup": "hola.html",
        "default_icon": "icon/bug-2-line.png"
    },

    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["ocultar.js"]
        }
    ]
}
